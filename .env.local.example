# Copy this file to .env.local and fill in all values.
# NEVER commit .env.local to git.

# -----------------------------------------------
# Next.js
# -----------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -----------------------------------------------
# Database (Supabase)
# DATABASE_URL:  pooled connection via PgBouncer (port 6543)
# DIRECT_URL:    direct Postgres connection (port 5432) — used by Prisma Migrate
# IMPORTANT: URL-encode passwords with special chars (@, :, /, ?, #, %) before putting them in URL.
# -----------------------------------------------
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-eu-north-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres"

# -----------------------------------------------
# NextAuth.js
# Generate NEXTAUTH_SECRET with: openssl rand -base64 32
# -----------------------------------------------
NEXTAUTH_SECRET="your-secret-here"
NEXTAUTH_URL=http://localhost:3000

# -----------------------------------------------
# Discord OAuth2
# Create app at: https://discord.com/developers/applications
# Add redirect URI: http://localhost:3000/api/auth/callback/discord
# Also add production redirect URI: https://<your-domain>/api/auth/callback/discord
# -----------------------------------------------
DISCORD_CLIENT_ID="your-discord-client-id"
DISCORD_CLIENT_SECRET="your-discord-client-secret"

# -----------------------------------------------
# Admin access
# ADMIN_DISCORD_ID: single admin account
# ADMIN_DISCORD_IDS: comma-separated list for multiple admins
# Example: ADMIN_DISCORD_IDS="123456789012345678,987654321098765432"
# -----------------------------------------------
ADMIN_DISCORD_ID=""
ADMIN_DISCORD_IDS=""

# -----------------------------------------------
# Stripe
# Get keys from: https://dashboard.stripe.com/test/apikeys
# -----------------------------------------------
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_GOLD_PRICE_ID="price_..."
STRIPE_PREMIUM_PRICE_ID="price_..."

# -----------------------------------------------
# Security
# Any random string — used to salt IP hashes in affiliate tracking
# -----------------------------------------------
IP_HASH_SECRET="your-random-salt-here"

# -----------------------------------------------
# Discord Bot (notifications + slash commands)
# Create bot at: https://discord.com/developers/applications
# Enable "Server Members Intent" under Bot → Privileged Gateway Intents
# -----------------------------------------------

# Bot credentials
DISCORD_BOT_TOKEN="your-bot-token"
DISCORD_APPLICATION_ID="your-application-id"

# Public key (for slash command signature verification)
# Found in: Developer Portal → Your App → General Information → Public Key
DISCORD_PUBLIC_KEY="your-app-public-key"

# Guild (server) ID — right-click your server → Copy Server ID (enable Developer Mode first)
DISCORD_GUILD_ID="your-server-id"

# Channel IDs for notifications — right-click channel → Copy Channel ID
DISCORD_FORUM_CHANNEL_ID=""         # New forum posts
DISCORD_ANNOUNCEMENTS_CHANNEL_ID="" # Level up announcements
DISCORD_LOOT_CHANNEL_ID=""          # Loot drops (falls back to announcements if empty)
DISCORD_MEMBER_JOIN_CHANNEL_ID=""   # New member join announcements

# Cron auth + optional explicit target URL (Railway)
CRON_SECRET="your-long-random-secret"
CRON_TARGET_URL="https://your-app.up.railway.app"

# Discord invite link shown to users
NEXT_PUBLIC_DISCORD_INVITE_URL="https://discord.gg/your-code"

# Role IDs for Loot Alert ping and tier sync — right-click role → Copy Role ID
# You can use EITHER naming convention below — the app checks both.
DISCORD_LOOT_ALERT_ROLE_ID=""

# Tier-based role names (used by admin panel tier sync)
DISCORD_ROOKIE_ROLE_ID=""
DISCORD_GRINDER_ROLE_ID=""
DISCORD_LEGEND_ROLE_ID=""
DISCORD_PREMIUM_ROLE_ID=""
DISCORD_GOLD_ROLE_ID=""
DISCORD_FREE_ROLE_ID=""

# Level-based role names (used by level-up milestone sync)
# Only needed if you use different role IDs than the tier roles above.
# DISCORD_LEVEL_1_ROLE_ID=""
# DISCORD_LEVEL_10_ROLE_ID=""
# DISCORD_LEVEL_25_ROLE_ID=""
# DISCORD_LEVEL_50_ROLE_ID=""
